# ── Servidor ────────────────────────────────────────────────────────────────
# El frontend en modo dev espera el API en el puerto 3051 (ver
# apps/web/src/environments/environment.ts). Usa 3051 en local.
PORT=3051

# ── Base de datos (obligatorio) ───────────────────────────────────────────────
# Sin MONGODB_URI el API no arranca.
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/zenda?retryWrites=true&w=majority

# ── Auth JWT (obligatorio) ────────────────────────────────────────────────────
JWT_SECRET=cambia-esto-por-un-secret-seguro
JWT_EXPIRES_IN=7d

# ── Stripe (obligatorio para el flujo de pago) ────────────────────────────────
# La reserva solo pasa de 'pendiente' a 'confirmada' cuando Stripe llama al
# webhook POST /api/v1/payments/webhook. En local usa:
#   stripe listen --forward-to localhost:3051/api/v1/payments/webhook
# y copia el whsec_... que imprime en STRIPE_WEBHOOK_SECRET.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Subida de imágenes a S3 (opcional) ────────────────────────────────────────
# Solo se necesita para POST /upload/image (fotos de listados). El API arranca
# sin estas vars; la subida devuelve 503 hasta configurarlas.
S3_REGION=eu-west-1
S3_BUCKET=doogking-uploads
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── Búsqueda con IA / DeepSeek (opcional) ─────────────────────────────────────
# Solo se necesita para POST /ai-search. Sin la key, el buscador cae al
# formulario manual (no rompe nada).
DEEPSEEK_API_KEY=

# ── Email transaccional / SMTP (opcional) ─────────────────────────────────────
# Confirmación de reserva al cliente + alerta de nueva reserva al comercio,
# tras el webhook de pago aprobado. Sin SMTP_HOST el API arranca igual; el
# intento de envío queda registrado como 'fallido' en la colección
# 'notificaciones' (outbox) en vez de perderse.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Doogking <no-reply@doogking.eu>
